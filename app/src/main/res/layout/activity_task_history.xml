<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/task_history_back_button"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:text="@string/task_navigation_back"
            android:textAllCaps="false"
            android:textColor="@color/task_prompt_accent_light"
            app:backgroundTint="@android:color/transparent" />

        <TextView
            android:id="@+id/task_history_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/task_history_title"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/task_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_primary"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabIndicatorColor="@color/task_prompt_accent"
        app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="@color/task_prompt_accent_light"
        app:tabTextColor="@color/task_prompt_text_secondary"
        app:tabRippleColor="@color/task_prompt_chip_info_bg" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Dashboard Tab Content -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/task_dashboard_swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

        <ScrollView
            android:id="@+id/task_dashboard_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Performance Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/task_prompt_input_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/task_prompt_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_activity"
                                app:tint="@color/task_prompt_accent"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dashboard_performance"
                                android:textAllCaps="true"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/dashboard_performance_sample_hint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_clock"
                                app:tint="@color/task_prompt_text_secondary"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dashboard_avg_duration"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/dashboard_avg_duration_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="2m 30s" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/task_prompt_stroke" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_footprints"
                                app:tint="@color/task_prompt_text_secondary"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dashboard_avg_steps"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/dashboard_avg_steps_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="42" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/task_prompt_stroke" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_brain"
                                app:tint="@color/task_prompt_text_secondary"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dashboard_top_model"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/dashboard_top_model_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="gemini-2.5-flash" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Activity Sparkline Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/task_prompt_input_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/task_prompt_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_list_tree"
                                app:tint="@color/task_prompt_accent"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dashboard_activity_label"
                                android:textAllCaps="true"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dashboard_last_14_days"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <com.mobilerun.portal.ui.taskprompt.SparklineView
                            android:id="@+id/dashboard_sparkline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Success Rate Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/task_prompt_input_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/task_prompt_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dashboard_success_rate"
                                android:textAllCaps="true"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/dashboard_success_rate_sample_hint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/dashboard_success_rate_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_white"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    tools:text="85.0%" />

                                <TextView
                                    android:id="@+id/dashboard_success_rate_detail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textColor="@color/task_prompt_text_secondary"
                                    android:textSize="12sp"
                                    tools:text="17 done · 3 failed" />

                            </LinearLayout>

                            <com.mobilerun.portal.ui.taskprompt.SuccessRingView
                                android:id="@+id/dashboard_success_ring"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_marginStart="16dp" />

                        </LinearLayout>

                        <!-- Status Legend -->
                        <LinearLayout
                            android:id="@+id/dashboard_status_legend"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Total Runs Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/task_prompt_input_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/task_prompt_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/dashboard_total_runs"
                            android:textAllCaps="true"
                            android:textColor="@color/task_prompt_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/dashboard_total_runs_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_white"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            tools:text="142" />

                        <TextView
                            android:id="@+id/dashboard_total_runs_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/task_prompt_text_secondary"
                            android:textSize="12sp"
                            tools:text="last task 2h ago" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Dashboard Loading -->
        <LinearLayout
            android:id="@+id/task_dashboard_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/task_prompt_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/dashboard_loading"
                android:textColor="@color/task_prompt_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Dashboard Error -->
        <LinearLayout
            android:id="@+id/task_dashboard_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/dashboard_error"
                android:textColor="@color/task_prompt_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/task_dashboard_retry_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="14dp"
                android:text="@string/retry"
                android:textAllCaps="false"
                app:backgroundTint="@color/mobilerun_primary" />

        </LinearLayout>

        <!-- History Tab Content -->
        <LinearLayout
            android:id="@+id/task_history_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:hint="@string/task_history_search_hint"
                app:boxBackgroundColor="@color/task_prompt_input_surface"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/task_prompt_stroke"
                app:hintTextColor="@color/task_prompt_text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/task_history_search_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:textColor="@color/task_prompt_text_primary"
                    android:textColorHint="@color/task_prompt_text_secondary"
                    android:textCursorDrawable="@drawable/task_prompt_cursor" />

            </com.google.android.material.textfield.TextInputLayout>

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/task_history_swipe_refresh"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="12dp">

                <LinearLayout
                    android:id="@+id/task_history_loading_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ProgressBar
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminateTint="@color/task_prompt_accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/task_history_loading"
                        android:textColor="@color/task_prompt_text_secondary"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/task_history_empty_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/task_history_empty_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/task_history_empty"
                        android:textColor="@color/task_prompt_text_secondary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/task_history_retry_button"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/retry"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:backgroundTint="@color/mobilerun_primary" />

                </LinearLayout>

                <ListView
                    android:id="@+id/task_history_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="10dp"
                    android:listSelector="@android:color/transparent"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone" />

            </FrameLayout>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
